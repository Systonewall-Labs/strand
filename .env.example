DATABASE_URL=file:./dev.db
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Security
ALLOWED_ORIGINS=https://your-app.your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_PAYLOAD_SIZE=1mb

# Session secret for cookie signing (required in production)
# Generate a secure random secret using: openssl rand -base64 32
SESSION_SECRET=your_secure_random_secret_here

# Email
RESEND_API_KEY=your_resend_api_key_here
EMAIL_DOMAIN=strand.app